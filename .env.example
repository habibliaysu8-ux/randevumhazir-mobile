# Render otomatik PORT verir. Localde gerekirse 3000 kullanılır.
PORT=3000
NODE_ENV=production

# CANLI LINK: Render linkin veya domainin. Şifremi unuttum linki buna göre oluşur.
PUBLIC_BASE_URL=https://randevumhazir-mobile.onrender.com

# KALICI DATABASE: Supabase/Render PostgreSQL connection string.
# Boş bırakırsan data/db.json kullanır; gerçek kullanım için boş bırakma.
DATABASE_URL=postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_SSL=true

# MAIL / SMTP: Gmail App Password, Resend SMTP veya başka SMTP olabilir.
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_SECURE=false
MAIL_USER=seninmailin@gmail.com
MAIL_PASS=GOOGLE_APP_PASSWORD
MAIL_FROM="Randevumhazır <seninmailin@gmail.com>"

# İlk admin hesabı. Database ilk kurulduğunda oluşur.
ADMIN_EMAIL=admin@randevumhazir.com
ADMIN_PASSWORD=Admin123!
ADMIN_NAME=Randevumhazır Admin
